datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Article {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  authorName   String
  authorBio    String?
  category     String
  annotation   String   @db.Text
  imageUrl     String
  imageAlt     String
  content      Json
  sources      Json
  createdAt    DateTime @default(now())
  published    Boolean  @default(true)

  // поля для RSS
  externalUrl  String?  @unique
  sourceSite   String?
  sourceRssUrl String?
  guid         String?
  rawHtml      String?
  importedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ImportRun {
  id         String   @id @default(uuid())
  jobName    String
  status     String
  trigger    String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  message    String?
  createdAt  DateTime @default(now())

  @@index([jobName, status, startedAt])
}